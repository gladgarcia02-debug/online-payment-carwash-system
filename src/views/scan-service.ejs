<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="container">
    <a class="back-link" href="/scan/<%= machine.code %>">&larr; Back</a>
    <p class="muted bay-label"><%= machine.name %></p>
    <h1><%= service.name %></h1>
    <% if (service.description) { %>
    <p class="muted"><%= service.description %></p>
    <% } %>

    <p class="section-label">Select duration</p>
    <div class="option-list">
      <% service.pricingOptions.forEach(option => { %>
      <form method="POST" action="/checkout">
        <input type="hidden" name="machineCode"      value="<%= machine.code %>" />
        <input type="hidden" name="serviceCode"      value="<%= service.code %>" />
        <input type="hidden" name="durationMinutes"  value="<%= option.duration_minutes %>" />
        <button type="submit" class="option-btn">
          <span class="option-duration"><%= option.duration_minutes %> min</span>
          <span class="option-price"><%= option.currency %> <%= Number(option.price).toFixed(2) %></span>
        </button>
      </form>
      <% }) %>
    </div>
  </main>
</body>
</html>
